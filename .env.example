# Minimal public ai-gram example configuration.
# Copy this file to .env.local for local examples. Do not commit real tokens or secrets.

# Required by most examples.
AIGRAM_BOT_TOKEN=

# Optional target chat/user values for examples that send messages.
AIGRAM_CHAT_ID=
AIGRAM_ADMIN_USER_IDS=
AIGRAM_ALLOWED_USER_IDS=
AIGRAM_ALLOWED_CHAT_IDS=
AIGRAM_ACCESS_MODE=admin

# Optional webhook example settings.
AIGRAM_TRANSPORT=polling
AIGRAM_WEBHOOK_URL=
AIGRAM_WEBHOOK_SECRET=
AIGRAM_LISTEN_ADDR=:8080
AIGRAM_WEBHOOK_PATH=/webhook

# Optional custom Bot API endpoint, for example a local Telegram Bot API server.
AIGRAM_BASE_URL=
AIGRAM_FILE_BASE_URL=

# Optional media example inputs.
AIGRAM_MEDIA_PATH=
AIGRAM_FILE_ID=

# Optional retry sender example settings.
AIGRAM_RETRY_TEXT=
AIGRAM_RETRY_MAX_ATTEMPTS=4
AIGRAM_RETRY_ATTEMPT_TIMEOUT=10s
AIGRAM_RETRY_BASE_DELAY=1s
AIGRAM_RETRY_MAX_DELAY=30s

# Optional maintainer max API smoke bot settings.
# once: sends a broad safe smoke suite to AIGRAM_CHAT_ID and exits.
# poll: starts long polling and handles /start, /smoke, /media, /status.
AIGRAM_MAX_API_MODE=once
AIGRAM_MAX_API_DRY_RUN=0
AIGRAM_MAX_API_RUN_SECONDS=120
AIGRAM_MAX_API_DELETE_WEBHOOK=0
AIGRAM_MAX_API_ALLOW_COMMANDS=0
AIGRAM_MAX_API_ALLOW_DELETE=0

# Maintainer live-smoke and deploy variables are intentionally not listed here.
# See docs/maintainer/ENV_SMOKE_TEMPLATE.md when working on maintainer smoke/deploy flows.
